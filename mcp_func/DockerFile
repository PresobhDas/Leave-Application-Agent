FROM python:3.12-slim

WORKDIR /app

# Good Python container defaults
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Install uv
RUN pip install --no-cache-dir uv

# Copy dependency files from repo root
COPY pyproject.toml uv.lock ./

# Install only locked runtime dependencies into /app/.venv
RUN uv sync --frozen --no-dev --no-install-project

# Copy application code
COPY mcp_func /app/mcp_func
COPY utils /app/utils

# Optional: copy any root-level modules/files your app imports directly
COPY __init__.py /app/__init__.py

# Make the uv virtualenv the default Python
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app"

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "mcp_func.mcp_app:mcp_server", "--host", "0.0.0.0", "--port", "8000"]